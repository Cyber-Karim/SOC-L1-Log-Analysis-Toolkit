# ─────────────────────────────────────────────────────────────────────────────
#  SOC L1 Log Analysis Toolkit — Environment Variables
#
#  SETUP:
#    1. Copy this file:   cp .env.example .env
#    2. Fill in your keys below
#    3. Never commit .env to Git  ← already in .gitignore
#
#  Free API keys:
#    VirusTotal : https://www.virustotal.com/gui/sign-in
#    AbuseIPDB  : https://www.abuseipdb.com/register
#    Shodan     : https://account.shodan.io/register
# ─────────────────────────────────────────────────────────────────────────────


# ── Threat Intelligence APIs ──────────────────────────────────────────────────

# VirusTotal API v3 Key
# Get free key at: https://www.virustotal.com
# Free tier: 4 requests/minute, 500 requests/day
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AbuseIPDB API Key
# Get free key at: https://www.abuseipdb.com/register
# Free tier: 1,000 checks/day
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Shodan API Key
# Get free key at: https://account.shodan.io/register
# Free tier: 1 query credit/month (paid plans recommended for bulk)
SHODAN_API_KEY=your_shodan_api_key_here


# ── Elasticsearch / ELK Stack ─────────────────────────────────────────────────

# Elasticsearch superuser password (used by all ELK services)
ELASTIC_PASSWORD=changeme_use_strong_password

# Kibana system user password
# Must match the password set for the kibana_system built-in user
KIBANA_PASSWORD=changeme_use_strong_password

# Kibana saved objects encryption key (must be 32+ characters)
KIBANA_ENCRYPTION_KEY=generate_a_random_32_char_string_here


# ── Wazuh SIEM ────────────────────────────────────────────────────────────────

# Wazuh API credentials
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=MyS3cr37P450r.*-

# Wazuh dashboard credentials
WAZUH_DASHBOARD_USER=kibanaserver
WAZUH_DASHBOARD_PASSWORD=kibanaserver


# ── General Project Settings ──────────────────────────────────────────────────

# Log directory path (relative to project root)
LOG_DIR=./logs

# Default brute force threshold (failed attempts to trigger alert)
BRUTE_FORCE_THRESHOLD=5

# Default time window for brute force detection (seconds)
BRUTE_FORCE_WINDOW=120

# Default port scan threshold (unique ports from same IP)
PORT_SCAN_THRESHOLD=5

# Business hours start (24h format, used for off-hours login detection)
BUSINESS_HOURS_START=8

# Business hours end (24h format)
BUSINESS_HOURS_END=18

# AbuseIPDB max age of reports to consider (days)
ABUSEIPDB_MAX_AGE_DAYS=30

# Output directory for reports
REPORT_DIR=./reports


# ─────────────────────────────────────────────────────────────────────────────
#  SECURITY REMINDERS
#  • Add .env to your .gitignore (never commit real credentials)
#  • Rotate API keys if accidentally exposed
#  • Use strong unique passwords for ELASTIC_PASSWORD / KIBANA_PASSWORD
#  • In production, use Docker secrets or a vault (HashiCorp Vault, AWS SSM)
# ─────────────────────────────────────────────────────────────────────────────
